rules_version = '2';

// ============================================================================
//  Reglas de seguridad de Firebase Storage — descubre-tu-ciudad
//  Fotos de eventos/restaurantes propuestos por usuarios (formulario "Agregar evento").
// ============================================================================

service firebase.storage {
  match /b/{bucket}/o {

    // submissions/{uid}/{fileName} — fotos subidas al proponer un evento
    match /submissions/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Por defecto: todo lo demás denegado
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
